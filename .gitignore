# mdBook build output
/book/

# Plugin assets — generated by `mdbook-mermaid install .` / `mdbook-admonish install .`.
# The installed plugin version is the source of truth; CI regenerates these.
/theme/mermaid.min.js
/theme/mermaid-init.js
/theme/mdbook-admonish.css

# Captured telemetry working files (raw captures stay OUT of git — see methodology.md;
# only the curated, redacted event excerpts that ship inside chapters are committed)
/labs/captures/
*.evtx
*.pcap

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Local-only: excluded from the public book repo ────────────────────────────
# These stay on disk but are never published. The book (src/) plus the sensor
# configs it links — labs/{linux,windows}/sysmon-config.xml, labs/linux/audit.rules,
# labs/linux/bpftrace/*.bt, labs/macos/eslogger-cmds.sh — ARE tracked. Only the
# private capture harness, internal working data, and dev/design artifacts are ignored.

# Capture-orchestration harness (carries lab infra IPs + WinRM/SSH plumbing) and its runners
/labs/orchestrator/
labs/*/run-captures.*
labs/*/CAPTURE-REPORT.template.md
labs/*/README-captures.md
/labs/linux/PRE-RUN-UBUNTU.md
/labs/EMULATION-PLAN.md

# Internal working data (BAS coverage, telemetry grounding, threat-exemplar drafts,
# navigator layers, visibility source) — grounding inputs, not reader-facing book content
/data/

# Dev/design artifacts + generators (their output is already materialized under src/)
/mockups/
/docs/
/scripts/
/requirements.txt
/book.toml.preview-bak

# Project changelog holds internal authoring/tooling notes — not published
/CHANGELOG.md
